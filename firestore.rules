rules_version = '2';

// ═══════════════════════════════════════════════════════════
//  ASMDA Website — Cloud Firestore Security Rules
//  Project: asmda-website
//  Last updated: 2026
// ═══════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Public read-only collections ──────────────────────
    // Publications, announcements, services, leadership — anyone can read
    match /publications/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leadership/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /departments/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Contact / inquiry submissions ─────────────────────
    // Anyone can submit; only admins can read submissions
    match /contact_submissions/{docId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Track / project tracking ──────────────────────────
    match /projects/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Admin users list ──────────────────────────────────
    // Only admins can read/write the admins collection
    match /admins/{userId} {
      allow read, write: if isAdmin();
    }

    // ── Dashboard / admin-only data ───────────────────────
    match /dashboard/{docId} {
      allow read, write: if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
